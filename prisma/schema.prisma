generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  emailVerified     Boolean  @default(false)
  image             String?
  role              String   @default("USER") // USER, ADMIN, SUPERADMIN
  preferredLanguage String   @default("en") // 'en' or 'gu'
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Better Auth Relations
  sessions Session[]
  accounts Account[]

  // Membership Relations
  memberProfile  MemberProfile?
  payments       Payment[]
  auditLogs      AuditLog[]
  supportTickets SupportTicket[]

  @@index([email])
  @@index([role])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  provider              String
  password              String? // hashed password for credential provider
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model MemberProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  memberId   String   @unique // e.g., RAVP000001
  fatherName String
  gender     String
  dob        DateTime
  mobile     String   @unique // Required, even though OTP is email
  aadhaar    String?
  voterId    String?

  // Address
  state       String
  district    String
  taluka      String
  village     String
  fullAddress String
  pincode     String

  // Membership Details
  membershipType MembershipTier @default(PRIMARY)
  issueDate      DateTime       @default(now())

  // Assets
  qrCodeUrl String?

  // Referrals
  referralCode String          @unique // e.g., RAVP458963
  referredById String?
  referredBy   MemberProfile?  @relation("Referrals", fields: [referredById], references: [id])
  referrals    MemberProfile[] @relation("Referrals")

  // Status & Assignment
  status       MemberStatus @default(ACTIVE)
  assignedTeam String?
  assignedPost String?
  deletedAt    DateTime?

  officeBearers       OfficeBearer[]
  organizationHistory OrganizationHistory[]
  departmentMembers   DepartmentMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  membershipHistory MembershipHistory[]
  referralHistory   ReferralHistory[]   @relation("ReferredMember")
  referralsMade     ReferralHistory[]   @relation("Referrer")

  @@index([memberId])
  @@index([referralCode])
  @@index([mobile])
  @@index([status])
  @@index([userId])
}

enum MemberStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BLOCKED
  ARCHIVED
}

enum MembershipTier {
  PRIMARY
  LIFETIME_PRIMARY
  LIFETIME_ACTIVE
}

model MembershipHistory {
  id              String        @id @default(uuid())
  memberProfileId String
  memberProfile   MemberProfile @relation(fields: [memberProfileId], references: [id], onDelete: Cascade)

  fromTier   MembershipTier?
  toTier     MembershipTier
  amountPaid Int             @default(0) // in paise
  paymentId  String?

  createdAt DateTime @default(now())
}

model ReferralHistory {
  id         String        @id @default(uuid())
  referrerId String
  referrer   MemberProfile @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)

  referredId     String        @unique // A member can only be referred once
  referredMember MemberProfile @relation("ReferredMember", fields: [referredId], references: [id], onDelete: Cascade)

  status ReferralStatus @default(SUCCESS)

  createdAt DateTime @default(now())
}

enum ReferralStatus {
  SUCCESS
  PENDING
  INVALID
}

model Payment {
  id                String         @id @default(uuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  razorpayOrderId   String         @unique
  razorpayPaymentId String?        @unique
  amount            Int // In paise (100 = ₹1)
  status            PaymentStatus  @default(PENDING)
  upgradeTo         MembershipTier

  currency      String  @default("INR")
  paymentMethod String? // e.g., "UPI", "CARD", "NETBANKING"
  tax           Int     @default(0) // in paise
  errorMessage  String?

  invoice Invoice?
  receipt Receipt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([razorpayOrderId])
  @@index([status])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

model Invoice {
  id            String  @id @default(uuid())
  invoiceNumber String  @unique // e.g., INV-2026-000001
  paymentId     String  @unique
  payment       Payment @relation(fields: [paymentId], references: [id])

  fileUrl   String?
  createdAt DateTime @default(now())
}

model Receipt {
  id            String  @id @default(uuid())
  receiptNumber String  @unique // e.g., REC-2026-000001
  paymentId     String  @unique
  payment       Payment @relation(fields: [paymentId], references: [id])

  fileUrl   String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String
  ipAddress String?
  browser   String?
  result    String   @default("SUCCESS") // SUCCESS, FAILURE
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model SupportTicket {
  id           String @id @default(uuid())
  ticketNumber String @unique // e.g., TKT-2026-000001
  userId       String
  user         User   @relation(fields: [userId], references: [id])
  subject      String
  category     String
  priority     String @default("LOW") // LOW, MEDIUM, HIGH, URGENT
  status       String @default("OPEN") // OPEN, UNDER_REVIEW, IN_PROGRESS, RESOLVED, CLOSED, REJECTED
  description  String

  messages     TicketMessage[]
  attachments  TicketAttachment[]
  activityLogs TicketActivityLog[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
}

// ----------------------------------------------------
// Organization Management (Phase 5)
// ----------------------------------------------------

model OrganizationLevel {
  id       String @id @default(uuid())
  nameEn   String
  nameGu   String
  priority Int    @default(0) // e.g. 1=National, 2=State
  status   String @default("ACTIVE") // ACTIVE, INACTIVE

  units     OrganizationUnit[]
  positions Position[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model OrganizationUnit {
  id     String @id @default(uuid())
  nameEn String
  nameGu String

  levelId String
  level   OrganizationLevel @relation(fields: [levelId], references: [id])

  parentId String?
  parent   OrganizationUnit?  @relation("UnitHierarchy", fields: [parentId], references: [id])
  children OrganizationUnit[] @relation("UnitHierarchy")

  officeBearers OfficeBearer[]
  documents     OrganizationDocument[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model Position {
  id          String  @id @default(uuid())
  nameEn      String
  nameGu      String
  description String? @db.Text
  priority    Int     @default(0)
  status      String  @default("ACTIVE")

  levelId String? // Optional, if tied to a specific level
  level   OrganizationLevel? @relation(fields: [levelId], references: [id])

  officeBearers OfficeBearer[]
  histories     OrganizationHistory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model Department {
  id          String  @id @default(uuid())
  nameEn      String
  nameGu      String
  description String? @db.Text
  status      String  @default("ACTIVE")

  officeBearers     OfficeBearer[]
  departmentMembers DepartmentMember[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model OfficeBearer {
  id String @id @default(uuid())

  memberId String
  member   MemberProfile @relation(fields: [memberId], references: [id])

  positionId String
  position   Position @relation(fields: [positionId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  unitId String
  unit   OrganizationUnit @relation(fields: [unitId], references: [id])

  startDate DateTime  @default(now())
  endDate   DateTime?
  status    String    @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED

  appointmentOrder String?
  profilePhoto     String?
  signature        String?

  assignments OrganizationAssignment[]
  histories   OrganizationHistory[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model OrganizationAssignment {
  id             String       @id @default(uuid())
  officeBearerId String
  officeBearer   OfficeBearer @relation(fields: [officeBearerId], references: [id])

  action  String // e.g. CREATED, APPROVED, REVOKED
  remarks String? @db.Text

  createdAt DateTime @default(now())
  createdBy String?
}

model OrganizationHistory {
  id             String       @id @default(uuid())
  officeBearerId String
  officeBearer   OfficeBearer @relation(fields: [officeBearerId], references: [id])

  memberId String
  member   MemberProfile @relation(fields: [memberId], references: [id])

  positionId String
  position   Position @relation(fields: [positionId], references: [id])

  startDate DateTime
  endDate   DateTime
  reason    String? // e.g. PROMOTED, EXPIRED, RESIGNED

  createdAt DateTime @default(now())
  createdBy String?
}

model DepartmentMember {
  id           String     @id @default(uuid())
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])

  memberId String
  member   MemberProfile @relation(fields: [memberId], references: [id])

  role   String @default("MEMBER") // Could be VOLUNTEER, etc.
  status String @default("ACTIVE")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

model OrganizationDocument {
  id      String @id @default(uuid())
  title   String
  fileUrl String

  unitId String
  unit   OrganizationUnit @relation(fields: [unitId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?
  updatedBy String?
  deletedAt DateTime?
}

// ----------------------------------------------------
// Content Management System (Phase 7)
// ----------------------------------------------------

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model CmsPage {
  id     String        @id @default(uuid())
  status ContentStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations CmsPageTranslation[]
}

model CmsPageTranslation {
  id     String  @id @default(uuid())
  pageId String
  page   CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  language String // 'en' or 'gu'
  title    String
  slug     String @unique
  content  String @db.Text

  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pageId, language])
}

model MediaFile {
  id           String  @id @default(uuid())
  filename     String  @unique
  originalName String
  filePath     String? // Made optional for backwards compat if needed
  mimeType     String
  extension    String?
  size         Int // in bytes
  url          String // e.g., /uploads/images/file.webp
  folder       String? // e.g. "gallery", "news"

  newsMedia NewsMedia[]

  createdAt DateTime @default(now())
}

model FaqItem {
  id       String        @id @default(uuid())
  category String        @default("GENERAL")
  order    Int           @default(0)
  status   ContentStatus @default(PUBLISHED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations FaqTranslation[]
}

model FaqTranslation {
  id    String  @id @default(uuid())
  faqId String
  faq   FaqItem @relation(fields: [faqId], references: [id], onDelete: Cascade)

  language String // 'en' or 'gu'
  question String
  answer   String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([faqId, language])
}

// ----------------------------------------------------
// New Multilingual Modules
// ----------------------------------------------------

model Policy {
  id        String        @id @default(uuid())
  status    ContentStatus @default(PUBLISHED)
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  translations PolicyTranslation[]
}

model PolicyTranslation {
  id       String @id @default(uuid())
  policyId String
  policy   Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  language String // 'en' or 'gu'
  title    String
  slug     String @unique
  content  String @db.Text

  seoTitle       String?
  seoDescription String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([policyId, language])
}

model Menu {
  id        String   @id @default(uuid())
  location  String   @unique // HEADER, FOOTER, MOBILE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items MenuItem[]
}

model MenuItem {
  id       String     @id @default(uuid())
  menuId   String
  menu     Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parentId String?
  parent   MenuItem?  @relation("MenuItemHierarchy", fields: [parentId], references: [id])
  children MenuItem[] @relation("MenuItemHierarchy")

  url    String
  order  Int    @default(0)
  target String @default("_self")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations MenuItemTranslation[]
}

model MenuItemTranslation {
  id       String   @id @default(uuid())
  itemId   String
  item     MenuItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  language String
  title    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, language])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique // e.g. WELCOME, PASSWORD_RESET
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  translations EmailTemplateTranslation[]
}

model EmailTemplateTranslation {
  id         String        @id @default(uuid())
  templateId String
  template   EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  language   String

  subject String
  body    String @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateId, language])
}

model TicketMessage {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType String // "MEMBER" | "ADMIN"
  senderId   String // userId or adminId
  message    String
  createdAt  DateTime      @default(now())
}

model TicketAttachment {
  id         String        @id @default(uuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName   String
  fileUrl    String
  fileType   String
  uploadedAt DateTime      @default(now())
}

model TicketActivityLog {
  id          String        @id @default(uuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action      String // "CREATED", "STATUS_CHANGED", "REPLIED"
  performedBy String // userId or adminId
  createdAt   DateTime      @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  imageUrl    String?
  createdAt   DateTime @default(now())
}

// ----------------------------------------------------
// Enterprise News & Press Release System (Phase 8)
// ----------------------------------------------------

enum ArticleStatus {
  DRAFT
  REVIEW
  SCHEDULED
  PUBLISHED
  ARCHIVED
  REJECTED
}

model NewsArticle {
  id       String        @id @default(uuid())
  authorId String // Points to Admin User ID
  status   ArticleStatus @default(DRAFT)

  isFeatured     Boolean @default(false)
  isBreaking     Boolean @default(false)
  isPressRelease Boolean @default(false)

  views Int @default(0)

  publishedAt  DateTime?
  scheduledFor DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  translations NewsTranslation[]
  categories   NewsCategory[]
  tags         NewsTag[]
  media        NewsMedia[]
  seo          NewsSEO?
}

model NewsTranslation {
  id        String      @id @default(uuid())
  articleId String
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  language String // 'en' or 'gu'
  title    String
  slug     String  @unique
  summary  String? @db.Text
  content  String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, language])
}

model NewsCategory {
  id       String  @id @default(uuid())
  name     String  @unique // e.g., "Party News", "Press Release"
  slug     String  @unique
  isActive Boolean @default(true)

  articles NewsArticle[]
}

model NewsTag {
  id   String @id @default(uuid())
  name String @unique // e.g., "Gujarat", "Youth"
  slug String @unique

  articles NewsArticle[]
}

enum MediaType {
  FEATURED_IMAGE
  GALLERY_IMAGE
  VIDEO
  DOCUMENT
}

model NewsMedia {
  id        String      @id @default(uuid())
  articleId String
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  mediaId String
  media   MediaFile @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  type    MediaType @default(GALLERY_IMAGE)
  order   Int       @default(0)
  caption String?
}

model NewsSEO {
  id        String      @id @default(uuid())
  articleId String      @unique
  article   NewsArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)

  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  canonicalUrl    String?
  ogImage         String?
}

model DownloadableAsset {
  id        String   @id @default(uuid())
  title     String
  category  String // Policy, Form, Guideline
  fileUrl   String
  createdAt DateTime @default(now())
}

// ----------------------------------------------------
// Contact & Inquiry Management System (Module 007-01)
// ----------------------------------------------------

enum ContactInquiryStatus {
  NEW
  PENDING
  IN_PROGRESS
  REPLIED
  CLOSED
}

enum ContactInquiryPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model ContactInquiry {
  id           String                 @id @default(uuid())
  inquiryId    String                 @unique // e.g. INQ-2026-000001
  fullName     String
  mobileNumber String
  email        String
  state        String
  district     String
  taluka       String
  subject      String
  message      String                 @db.Text
  status       ContactInquiryStatus   @default(NEW)
  priority     ContactInquiryPriority @default(MEDIUM)
  assignedTo   String?                // User / Admin name or ID
  archived     Boolean                @default(false)
  replyNotes   String?                @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activityLogs ContactActivityLog[]

  @@index([status])
  @@index([priority])
  @@index([state])
  @@index([district])
  @@index([createdAt])
}

model ContactOffice {
  id             String  @id @default(uuid())
  officeNameEn   String
  officeNameGu   String
  addressEn      String  @db.Text
  addressGu      String  @db.Text
  phone          String
  email          String
  website        String
  googleMapUrl   String? @db.Text
  embedMapUrl    String? @db.Text
  isHeadquarters Boolean @default(true)
  order          Int     @default(0)

  workingHours ContactWorkingHour[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactWorkingHour {
  id         String         @id @default(uuid())
  officeId   String?
  office     ContactOffice? @relation(fields: [officeId], references: [id], onDelete: Cascade)
  dayRangeEn String         // e.g. "Monday – Saturday"
  dayRangeGu String         // e.g. "સોમવાર – શનિવાર"
  timingEn   String         // e.g. "10:00 AM – 6:00 PM"
  timingGu   String         // e.g. "સવારે 10:00 – સાંજે 6:00"
  isClosed   Boolean        @default(false)
  order      Int            @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSocialLink {
  id             String  @id @default(uuid())
  platform       String  @unique // FACEBOOK, INSTAGRAM, TWITTER, YOUTUBE, WHATSAPP, TELEGRAM, LINKEDIN, THREADS
  platformNameEn String
  platformNameGu String
  url            String?
  icon           String?
  isEnabled      Boolean @default(true)
  order          Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactFaq {
  id         String  @id @default(uuid())
  questionEn String
  questionGu String
  answerEn   String  @db.Text
  answerGu   String  @db.Text
  category   String  @default("GENERAL")
  order      Int     @default(0)
  isEnabled  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSetting {
  id        String   @id @default(uuid())
  key       String   @unique // e.g. 'contact_hero', 'contact_intro', 'contact_join', 'contact_commitment', 'contact_motto', 'contact_seo'
  value     String   @db.Text // JSON formatted string containing bilingual attributes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactActivityLog {
  id          String         @id @default(uuid())
  inquiryId   String
  inquiry     ContactInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  action      String         // CREATED, STATUS_CHANGED, ASSIGNED, PRIORITY_CHANGED, REPLIED, ARCHIVED
  performedBy String         // e.g. "System" or Admin User name
  remarks     String?        @db.Text

  createdAt DateTime @default(now())
}

// ----------------------------------------------------
// FAQ Management System (Module 007-02)
// ----------------------------------------------------

model FaqCategory {
  id        String   @id @default(uuid())
  nameGu    String
  nameEn    String
  slug      String   @unique
  icon      String?  @default("HelpCircle")
  sortOrder Int      @default(0)
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE

  faqs Faq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Faq {
  id              String      @id @default(uuid())
  categoryId      String
  category        FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questionGu      String
  questionEn      String
  answerGu        String      @db.Text
  answerEn        String      @db.Text
  featured        Boolean     @default(false)
  published       Boolean     @default(true)
  sortOrder       Int         @default(0)
  views           Int         @default(0)
  helpfulCount    Int         @default(0)
  notHelpfulCount Int         @default(0)
  metaTitle       String?
  metaDescription String?
  keywords        String?
  slug            String      @unique
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?   // Soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([published])
  @@index([featured])
  @@index([slug])
}


