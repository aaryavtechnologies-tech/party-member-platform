generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("USER") // USER, ADMIN, SUPERADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Better Auth Relations
  sessions      Session[]
  accounts      Account[]

  // Membership Relations
  memberProfile MemberProfile?
  payments      Payment[]
  auditLogs     AuditLog[]
  supportTickets SupportTicket[]
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId            String
  accountId             String
  provider              String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MemberProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  memberId        String   @unique // e.g., RAVP000001
  fatherName      String
  gender          String
  dob             DateTime
  mobile          String   @unique // Required, even though OTP is email
  aadhaar         String?
  voterId         String?
  
  // Address
  state           String
  district        String
  taluka          String
  village         String
  fullAddress     String
  pincode         String

  // Membership Details
  membershipType  MembershipTier @default(PRIMARY)
  issueDate       DateTime       @default(now())
  
  // Assets
  qrCodeUrl       String?
  
  // Referrals
  referralCode    String   @unique // e.g., RAVP458963
  referredById    String?
  referredBy      MemberProfile?  @relation("Referrals", fields: [referredById], references: [id])
  referrals       MemberProfile[] @relation("Referrals")

  // Status & Assignment
  status          MemberStatus @default(ACTIVE)
  assignedTeam    String?
  assignedPost    String?
  deletedAt       DateTime?
  
  organizationAssignments OrganizationAssignment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum MemberStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BLOCKED
  ARCHIVED
}

enum MembershipTier {
  PRIMARY
  LIFETIME_PRIMARY
  LIFETIME_ACTIVE
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  razorpayOrderId String   @unique
  razorpayPaymentId String? @unique
  amount          Int      // In paise (100 = ₹1)
  status          PaymentStatus @default(PENDING)
  upgradeTo       MembershipTier
  
  currency        String   @default("INR")
  paymentMethod   String?  // e.g., "UPI", "CARD", "NETBANKING"
  tax             Int      @default(0) // in paise
  errorMessage    String?
  
  invoice         Invoice?
  receipt         Receipt?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique // e.g., INV-2026-000001
  paymentId     String   @unique
  payment       Payment  @relation(fields: [paymentId], references: [id])
  
  fileUrl       String?
  createdAt     DateTime @default(now())
}

model Receipt {
  id            String   @id @default(uuid())
  receiptNumber String   @unique // e.g., REC-2026-000001
  paymentId     String   @unique
  payment       Payment  @relation(fields: [paymentId], references: [id])
  
  fileUrl       String?
  createdAt     DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String
  createdAt DateTime @default(now())
}

model SupportTicket {
  id           String    @id @default(uuid())
  ticketNumber String    @unique // e.g., TKT-2026-000001
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  subject      String
  category     String
  priority     String    @default("LOW") // LOW, MEDIUM, HIGH, URGENT
  status       String    @default("OPEN") // OPEN, UNDER_REVIEW, IN_PROGRESS, RESOLVED, CLOSED, REJECTED
  description  String
  
  messages     TicketMessage[]
  attachments  TicketAttachment[]
  activityLogs TicketActivityLog[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?
}

// ----------------------------------------------------
// Organization Management (Phase 5)
// ----------------------------------------------------

enum OrgLevel {
  NATIONAL
  STATE
  DISTRICT
  TALUKA
  VILLAGE
}

model OrganizationUnit {
  id          String   @id @default(uuid())
  name        String   // e.g., "Gujarat", "Ahmedabad"
  level       OrgLevel
  
  parentId    String?
  parent      OrganizationUnit?  @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    OrganizationUnit[] @relation("UnitHierarchy")

  assignments OrganizationAssignment[]
}

model OrganizationPosition {
  id          String   @id @default(uuid())
  title       String
  level       OrgLevel
  isActive    Boolean  @default(true)

  assignments OrganizationAssignment[]
}

model OrganizationAssignment {
  id           String   @id @default(uuid())
  
  memberId     String
  member       MemberProfile @relation(fields: [memberId], references: [id])
  
  unitId       String
  unit         OrganizationUnit @relation(fields: [unitId], references: [id])
  
  positionId   String
  position     OrganizationPosition @relation(fields: [positionId], references: [id])

  startDate    DateTime @default(now())
  endDate      DateTime?
  status       String   @default("ACTIVE") // ACTIVE, EXPIRED, REVOKED
  remarks      String?

  createdAt    DateTime @default(now())
}


model TicketMessage {
  id           String    @id @default(uuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType   String    // "MEMBER" | "ADMIN"
  senderId     String    // userId or adminId
  message      String
  createdAt    DateTime  @default(now())
}

model TicketAttachment {
  id           String    @id @default(uuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName     String
  fileUrl      String
  fileType     String
  uploadedAt   DateTime  @default(now())
}

model TicketActivityLog {
  id           String    @id @default(uuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  action       String    // "CREATED", "STATUS_CHANGED", "REPLIED"
  performedBy  String    // userId or adminId
  createdAt    DateTime  @default(now())
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  date        DateTime
  location    String
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model News {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String
  imageUrl    String?
  publishedAt DateTime @default(now())
}

model DownloadableAsset {
  id          String   @id @default(uuid())
  title       String
  category    String   // Policy, Form, Guideline
  fileUrl     String
  createdAt   DateTime @default(now())
}
